# .dockerignore para variante full (Ubuntu + Java + Gradle)
# Build context: raíz del proyecto (docker build -f docker/full/Dockerfile .)

# Credentials and local config — NEVER in image
.env.local
.env*

# Claude / IDE / editor
.claude/
.vscode/
.idea/
*.swp
*.swo

# Docs and architecture
architecture/
README.md
CLAUDE.md
TODO.md
*.md

# Scripts operativos — solo se usan en el host
1-build-agent.sh
2-start-agent.sh
3-test-agent.sh
build-lite.sh
start-lite.sh
Dockerfile
Dockerfile.*

# Tests — no se ejecutan en el contenedor
tests/

# Business input files — llegan por multipart en el request
requirements/
fixtures/rules/business-reference/

# Local artifacts
data/
logs/
site/
tests/migrations/
docker/

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.coverage

# Conda / pip env
environment.yml
.conda/
*.egg-info/
dist/
build/

# OS
.DS_Store

# gradle/local-repo/ se extrae desde local-repo.tar.gz en 1-build-base.sh
# y se copia explícitamente en Dockerfile.base — no excluir gradle/
